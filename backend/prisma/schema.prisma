// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String   @map("password_hash")
  name          String
  emailVerified Boolean  @default(false) @map("email_verified")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  gitlabConnections GitLabConnection[]
  projects          Project[]
  timeEntries       TimeEntry[]
  dashboards        Dashboard[]
  exports           Export[]
  auditLogs         AuditLog[]
  refreshTokens     RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model GitLabConnection {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  gitlabUrl             String    @map("gitlab_url")
  accessTokenEncrypted  String?   @map("access_token_encrypted")
  keyVaultSecretId      String?   @map("key_vault_secret_id")
  connectionName        String    @map("connection_name")
  isActive              Boolean   @default(true) @map("is_active")
  lastSyncedAt          DateTime? @map("last_synced_at")
  createdAt             DateTime  @default(now()) @map("created_at")

  // Relations
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  projects Project[]

  @@index([userId])
  @@map("gitlab_connections")
}

model Project {
  id                  String   @id @default(uuid())
  userId              String   @map("user_id")
  gitlabConnectionId  String   @map("gitlab_connection_id")
  gitlabProjectId     String   @map("gitlab_project_id")
  projectName         String   @map("project_name")
  projectPath         String   @map("project_path")
  isFavorite          Boolean  @default(false) @map("is_favorite")
  createdAt           DateTime @default(now()) @map("created_at")

  // Relations
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  gitlabConnection  GitLabConnection @relation(fields: [gitlabConnectionId], references: [id], onDelete: Cascade)
  timeEntries       TimeEntry[]

  @@unique([userId, gitlabConnectionId, gitlabProjectId])
  @@index([userId])
  @@index([gitlabConnectionId])
  @@map("projects")
}

model TimeEntry {
  id               String   @id @default(uuid())
  projectId        String   @map("project_id")
  userId           String   @map("user_id")
  gitlabIssueIid   String   @map("gitlab_issue_iid")
  gitlabIssueTitle String   @map("gitlab_issue_title")
  author           String
  spentHours       Float    @map("spent_hours")
  spentAt          DateTime @map("spent_at")
  commentSummary   String?  @map("comment_summary")
  isNegative       Boolean  @default(false) @map("is_negative")
  syncedAt         DateTime @default(now()) @map("synced_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([spentAt])
  @@index([author])
  @@map("time_entries")
}

model Dashboard {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  name       String
  configJson String   @map("config_json")
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dashboards")
}

model Export {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  fileUrl     String   @map("file_url")
  fileType    String   @map("file_type")
  generatedAt DateTime @default(now()) @map("generated_at")
  expiresAt   DateTime @map("expires_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("exports")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  action       String
  resourceType String?  @map("resource_type")
  resourceId   String?  @map("resource_id")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  timestamp    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}
